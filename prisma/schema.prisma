  ScheduledDueDate      DateTime  @db.DateTime
  EstimatedHours        Int?
  TaskTypeID            Int?
  AssignedToID          Int?
  DateStarted           DateTime? @db.DateTime
  DateCompleted         DateTime? @db.DateTime
  ManualDueDate         Int?      @db.SmallInt
  CreatedTimestamp      DateTime? @db.DateTime
